{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auger",
  "version": "0.1.0",
  "identifier": "com.gaetandeturche.p4gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Auger",
        "width": 1280,
        "height": 780,
        "minWidth": 900,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFQjcyRDgxRjE4Mzg2QjIKUldTeWhvUHhnUzIzanBMTzJDeitoQ3l0TUxiY0h4MTJkMlpyeUV2cXVyYS9Bc3FzWXRPVXM4d2EK",
      "endpoints": [
        "https://github.com/gaetan-deturche/p4-explorer/releases/latest/download/latest.json"
      ]
    }
  }
}
